# ──────────────────────────────────────────────────────────────────────────
# Branding (build-time)
# ──────────────────────────────────────────────────────────────────────────

# Display name for the participant group. Title becomes "<NAME> World Cup
# Sweepstakes", section headers say "<NAME> head-to-heads", etc. Inlined at
# build time — set in Vercel project env before deploy.
# Example: "Group", "Smith Crew", "Office 4B"
VITE_GROUP_NAME=Group

# ──────────────────────────────────────────────────────────────────────────
# Access control
# ──────────────────────────────────────────────────────────────────────────

# Shared passkey. Anyone visiting the site with `?key=<this value>` gets
# a year-long signed cookie set and is granted access; thereafter they
# bookmark the clean URL. Leave empty to disable auth (open site).
#
# Distribute the bookmark URL to participants — they never type the passkey
# themselves. Rotate by changing this value (invalidates all old cookies).
APP_PASSKEY=

# ──────────────────────────────────────────────────────────────────────────
# Sweepstakes secrets (per-participant data — never check these in)
# ──────────────────────────────────────────────────────────────────────────

# Participant list (YAML). Source-of-truth lives in your local teams.yaml.
# Push to Vercel with: npm run push-secrets
TEAMS_YAML=

# Output of the draw script (YAML mapping participant -> [teamCode, teamCode, teamCode]).
# Generated by: npm run draw
DRAW_YAML=

# ──────────────────────────────────────────────────────────────────────────
# Results data layer
# ──────────────────────────────────────────────────────────────────────────

# Which upstream provider the ResultsSource uses.
#   openfootball  default — keyless, GitHub-hosted, lags during live matches
#   api-football  api-sports.io, primary source for live scores (needs paid plan for 2026)
#   demo          synthetic scores overlaid on openfootball fixtures (dev only)
RESULTS_SOURCE=openfootball

# Cache TTL for the results bundle. Inside live windows the cache refreshes
# this often; outside live windows it's served stale (no upstream call).
RESULTS_TTL_SECONDS=120

# API-Football key (api-sports.io). Only used when RESULTS_SOURCE=api-football.
# Free plan does NOT cover WC 2026 — Pro plan or higher required.
API_FOOTBALL_KEY=

# API-Football season to query. Defaults to 2026. Set to 2022 to validate
# the adapter against the previous tournament on a free plan.
API_FOOTBALL_SEASON=2026

# ──────────────────────────────────────────────────────────────────────────
# Storage — Upstash Redis (free tier: 500K commands/month, 256 MB)
# ──────────────────────────────────────────────────────────────────────────

# REST credentials for Upstash Redis (sign up at upstash.com).
# When both are set, the server uses Upstash; otherwise it falls back to a
# local file cache at $CACHE_LOCAL_PATH (default ./.cache.local.json).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Local dev cache file (only used when Upstash isn't configured).
CACHE_LOCAL_PATH=
