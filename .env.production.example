# Copy to .env.production (gitignored), fill in values, then `npm run push-env`.
# One KEY=VALUE per line. Empty values are skipped. Quoted values OK.

# Branding
VITE_GROUP_NAME=

# Auth gate — pick a passkey, distribute the bookmark URL `?key=<this>`.
APP_PASSKEY=

# Results source: openfootball (default) or api-football
RESULTS_SOURCE=openfootball
RESULTS_TTL_SECONDS=120

# api-football credentials — only used when RESULTS_SOURCE=api-football
API_FOOTBALL_KEY=
API_FOOTBALL_SEASON=2026

# Upstash Redis REST (sign up at upstash.com — free tier)
KV_REST_API_URL=
KV_REST_API_TOKEN=
